# Quality Pulse Environment Configuration Template
# Copy this file to .env and fill in the actual values before running `docker-compose up`.

# PostgreSQL Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_postgres_password_here
POSTGRES_DB=qualitypulse

# Redis Configuration
REDIS_PASSWORD=your_secure_redis_password_here

# External APIs
# Gemini is required for the LLM Triage step (Track A)
GEMINI_API_KEY=your_gemini_api_key_here

# NewsAPI is optional but recommended for Track B (News Aggregation)
NEWS_API_KEY=your_news_api_key_here

# Domain configuration (only needed for production, docker-compose.prod.yml)
# DOMAIN_NAME=doodle-choi.me
