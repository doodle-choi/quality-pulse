# Quality Pulse Environment Configuration Template
# Copy this file to .env and fill in the actual values before running `docker-compose up`.

# ─── PostgreSQL Database ───────────────────────────────────────────────────────
# [IMPORTANT] If your password contains special characters like #, !, @, please wrap it in double quotes: "pass#word"
POSTGRES_USER=postgres
POSTGRES_PASSWORD="your_secure_postgres_password_here"
POSTGRES_DB=qualitypulse

# ─── Redis Cache ───────────────────────────────────────────────────────────────
REDIS_PASSWORD="your_secure_redis_password_here"

# ─── Backend & Internal Security ───────────────────────────────────────────────
# Internal API Key for secure communication between components
INTERNAL_API_KEY="your_secure_internal_api_key_here"

# ─── Frontend Next.js ──────────────────────────────────────────────────────────
# Secret for NextAuth (generate via: openssl rand -base64 32)
AUTH_SECRET="your_nextauth_secret_here"

# ─── External APIs (LLM & News) ────────────────────────────────────────────────
# Default LLM model is gemini/gemini-2.5-flash as per docker-compose
LLM_MODEL=gemini/gemini-2.5-flash
GEMINI_API_KEY=your_gemini_api_key_here
NEWS_API_KEY=your_news_api_key_here

# ─── Infrastructure ────────────────────────────────────────────────────────────
# Domain configuration (only needed for production, e.g. doodle-choi.me)
DOMAIN_NAME=doodle-choi.me
